diff --git a/src/signal/handler.c b/src/signal/handler.c
new file mode 100644
index 0000000..abc1234
--- /dev/null
+++ b/src/signal/handler.c
@@ -0,0 +1,25 @@
+#include <signal.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <unistd.h>
+
+static volatile sig_atomic_t signal_received = 0;
+
+void sigusr1_handler(int signo, siginfo_t *info, void *context) {
+    char buf[256];
+    snprintf(buf, sizeof(buf), "Received signal %d from pid %d\n", signo, info->si_pid);
+    write(STDOUT_FILENO, buf, strlen(buf));
+
+    char *env_val = getenv("DEBUG_MODE");
+    if (env_val != NULL && strcmp(env_val, "1") == 0) {
+        printf("Debug: signal details logged\n");
+    }
+
+    char *msg = (char *)malloc(128);
+    if (msg) {
+        strcpy(msg, "signal handled");
+        free(msg);
+    }
+
+    signal_received = 1;
+}
+
+void register_signal_handler(void) {
+    struct sigaction sa;
+    sa.sa_sigaction = sigusr1_handler;
+    sa.sa_flags = SA_SIGINFO;
+    sigemptyset(&sa.sa_mask);
+    sigaction(SIGUSR1, &sa, NULL);
+}
+
+void fork_with_logging(void) {
+    pid_t pid = fork();
+    if (pid == 0) {
+        printf("Child process started\n");
+        FILE *fp = fopen("/tmp/child.log", "w");
+        if (fp) {
+            fprintf(fp, "Child PID: %d\n", getpid());
+            fclose(fp);
+        }
+    }
+}
