    "ConfigurationFiles": {
      "module.json5": {
        "correct": "module.json5",
        "variants": ["module.json", "Module.json5"]
      },
      "oh-package.json5": {
        "correct": "oh-package.json5",
        "variants": ["oh-package.json", "ohPackage.json5"]
      },
      "build-profile.json5": {
        "correct": "build-profile.json5",
        "variants": ["buildProfile.json5", "build_profile.json5"]
      }
    },
    "Kits": {
      "@kit.ArkTS": {
        "correct": "@kit.ArkTS",
        "variants": ["@kit.arkts", "@ohos.arkts"]
      },
      "@kit.ArkUI": {
        "correct": "@kit.ArkUI",
        "variants": ["@kit.arkui", "@ohos.arkui"]
      },
      "@kit.AbilityKit": {
        "correct": "@kit.AbilityKit",
        "variants": ["@kit.abilitykit", "@ohos.abilitykit"]
      }
    }
  },
  "rules": [
    {
      "id": "spelling-001",
      "name": "common-misspelling",
      "description": "常见英文单词拼写错误",
      "type": "spelling",
      "priority": "medium",
      "confidence": 95,
      "enabled": true,
      "checkInCodeBlocks": false,
      "message": "\"{wrong}\" 拼写错误，应为 \"{correct}\"",
      "autoFixable": true
    },
    {
      "id": "spelling-002",
      "name": "harmonyos-glossary",
      "description": "鸿蒙专有名词大小写错误",
      "type": "spelling",
      "priority": "high",
      "confidence": 95,
      "enabled": true,
      "checkInCodeBlocks": true,
      "message": "\"{wrong}\" 应为 \"{correct}\"",
      "explanation": "鸿蒙专有名词应使用标准大小写形式",
      "autoFixable": true
    },
    {
      "id": "spelling-003",
      "name": "unknown-decorator",
      "description": "未知的装饰器",
      "type": "spelling",
      "priority": "medium",
      "confidence": 70,
      "enabled": true,
      "checkInCodeBlocks": true,
      "pattern": "@([A-Za-z]+)",
      "validDecorators": ["Entry", "Component", "State", "Prop", "Link", "Provide", "Consume", "Watch", "Builder", "CustomDialog", "Extend", "Styles", "Animate", "StorageLink", "StorageProp", "ObjectLink", "Observed"],
      "message": "未知装饰器 \"@{decorator}\"，请检查拼写",
      "autoFixable": false
    }
  ]
}
