{
  "version": "1.0.0",
  "description": "拼写检查规则，包括鸿蒙专有名词校验",
  "commonMisspellings": {
    "Javscript": "JavaScript",
    "javscript": "JavaScript",
    "recieve": "receive",
    "recive": "receive",
    "seperate": "separate",
    "separate": "separate",
    "occurance": "occurrence",
    "occurence": "occurrence",
    "authentification": "authentication",
    "autherization": "authorization",
    "refernce": "reference",
    "referene": "reference",
    "paramter": "parameter",
    "paramter": "parameter",
    "retreive": "retrieve",
    "retrive": "retrieve",
    "initalize": "initialize",
    "initialze": "initialize",
    "defualt": "default",
    "defaut": "default",
    "configration": "configuration",
    "configuraton": "configuration",
    "enviroment": "environment",
    "enviroment": "environment",
    "successfull": "successful",
    "succesful": "successful",
    "asyc": "async",
    "aync": "async",
    "fucntion": "function",
    "funtion": "function",
    "vlaue": "value",
    "vaue": "value",
    "calback": "callback",
    "callbak": "callback",
    "instace": "instance",
    "instnce": "instance",
    "propery": "property",
    "propert": "property",
    "methd": "method",
    "mehtod": "method",
    "destory": "destroy",
    "destory": "destroy",
    "destoryed": "destroyed"
  },
  "harmonyOSGlossary": {
    "AbilityFramework": {
      "UIAbility": {
        "correct": "UIAbility",
        "variants": ["UiAbility", "uiAbility", "UIability", "uiability"]
      },
      "AbilityStage": {
        "correct": "AbilityStage",
        "variants": ["Abilitystage", "abilityStage", "abilitystage"]
      },
      "ExtensionAbility": {
        "correct": "ExtensionAbility",
        "variants": ["Extensionability", "extensionAbility", "extensionability"]
      },
      "WindowStage": {
        "correct": "WindowStage",
        "variants": ["Windowstage", "windowStage", "windowstage"]
      },
      "EntryAbility": {
        "correct": "EntryAbility",
        "variants": ["Entryability", "entryAbility", "entryability"]
      }
    },
    "ContextTypes": {
      "UIAbilityContext": {
        "correct": "UIAbilityContext",
        "variants": ["UiAbilityContext", "uiAbilityContext", "UIabilityContext"]
      },
      "AbilityStageContext": {
        "correct": "AbilityStageContext",
        "variants": ["AbilitystageContext", "abilityStageContext"]
      },
      "ApplicationContext": {
        "correct": "ApplicationContext",
        "variants": ["Applicationcontext", "applicationContext"]
      },
      "BaseContext": {
        "correct": "BaseContext",
        "variants": ["Basecontext", "baseContext"]
      },
      "ExtensionAbilityContext": {
        "correct": "ExtensionAbilityContext",
        "variants": ["ExtensionabilityContext", "extensionAbilityContext"]
      }
    },
    "ModuleSystem": {
      "HAP": {
        "correct": "HAP",
        "variants": ["hap", "Hap"]
      },
      "HSP": {
        "correct": "HSP",
        "variants": ["hsp", "Hsp"]
      },
      "HAR": {
        "correct": "HAR",
        "variants": ["har", "Har"]
      }
    },
    "Decorators": {
      "@Entry": {
        "correct": "@Entry",
        "variants": ["@entry", "@ENTRY"]
      },
      "@Component": {
        "correct": "@Component",
        "variants": ["@component", "@COMPONENT"]
      },
      "@State": {
        "correct": "@State",
        "variants": ["@state", "@STATE"]
      },
      "@Prop": {
        "correct": "@Prop",
        "variants": ["@prop", "@PROP"]
      },
      "@Link": {
        "correct": "@Link",
        "variants": ["@link", "@LINK"]
      },
      "@Provide": {
        "correct": "@Provide",
        "variants": ["@provide", "@PROVIDE"]
      },
      "@Consume": {
        "correct": "@Consume",
        "variants": ["@consume", "@CONSUME"]
      },
      "@Watch": {
        "correct": "@Watch",
        "variants": ["@watch", "@WATCH"]
      },
      "@Builder": {
        "correct": "@Builder",
        "variants": ["@builder", "@BUILDER"]
      }
    },
    "CommonTypes": {
      "AsyncCallback": {
        "correct": "AsyncCallback",
        "variants": ["Asynccallback", "asyncCallback", "asynccallback"]
      },
      "Callback": {
        "correct": "Callback",
        "variants": ["callback", "CALLBACK"]
      },
      "ESObject": {
        "correct": "ESObject",
        "variants": ["Esobject", "esObject", "esobject", "ESobject"]
      },
      "BusinessError": {
        "correct": "BusinessError",
        "variants": ["Businesserror", "businessError", "businesserror"]
      },
      "Resource": {
        "correct": "Resource",
        "variants": ["resource"]
      },
